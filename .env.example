# Copy to `.env` at the repo root and fill in values.
# `.env` is gitignored — never commit secrets.

# --- Frontend (Vite exposes VITE_* to the browser) ---
VITE_MAPBOX_TOKEN=pk.example-mapbox-token

# --- Backend / Databricks SQL Warehouse ---
DATABRICKS_SERVER_HOSTNAME=dbc-example.cloud.databricks.com

DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/example
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=example_catalog
DATABRICKS_SCHEMA=example_schema
DATABRICKS_WELLS_TABLE=example_wells_table

# --- Project Setup / Launchpad (/api/setup/*) ---
# Full table the Launchpad filters narrow down (defaults to eds.well.tbl_well_summary_all).
SETUP_WELL_SUMMARY_TABLE=eds.well.tbl_well_summary_all
# Model-serving endpoint for natural-language query interpretation. Requires
# DATABRICKS_SERVER_HOSTNAME + DATABRICKS_TOKEN above. Set empty to force the
# deterministic heuristic parser. Defaults to databricks-meta-llama-3-3-70b-instruct.
DATABRICKS_MODEL_ENDPOINT=databricks-meta-llama-3-3-70b-instruct
