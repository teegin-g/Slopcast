{
  "$schema": "https://react.doctor/schema/config.json",
  "lint": true,
  "rules": {
    "react-doctor/no-unknown-property": "off",
    "react-doctor/no-adjust-state-on-prop-change": "off",
    "react-doctor/effect-needs-cleanup": "off",
    "react-doctor/prefer-dynamic-import": "off",
    "react-doctor/prefer-tag-over-role": "off",
    "react-doctor/js-tosorted-immutable": "off",
    "react-doctor/no-react19-deprecated-apis": "off",
    "react-doctor/no-event-handler": "off",
    "react-doctor/exhaustive-deps": "off",
    "react-doctor/no-cascading-set-state": "off",
    "react-doctor/no-chain-state-updates": "off",
    "react-doctor/no-derived-state": "off",
    "react-doctor/no-derived-useState": "off",
    "react-doctor/no-initialize-state": "off",
    "react-doctor/rerender-state-only-in-handlers": "off",
    "react-doctor/async-defer-await": "off",
    "react-doctor/no-many-boolean-props": "off",
    "react-doctor/no-pass-data-to-parent": "off",
    "react-doctor/no-pass-live-state-to-parent": "off",
    "react-doctor/prefer-html-dialog": "off",
    "react-doctor/unused-export": "off",
    "react-doctor/unused-dev-dependency": "off",
    "react-doctor/no-giant-component": "off",
    "react-doctor/prefer-useReducer": "off"
  },
  "ignore": {
    "rules": [
      "react-doctor/unused-export",
      "react-doctor/unused-dev-dependency",
      "unused-export",
      "unused-dev-dependency"
    ],
    "files": [
      "src/components/slopcast/map/lateralLayerController.ts",
      "src/components/slopcast/map/sectionLayerController.ts",
      "src/hooks/useViewportFeatureData.ts"
    ]
  }
}
