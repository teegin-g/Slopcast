{
  "name": "slopcast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "./scripts/start-backend.sh",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test": "vitest run --project storybook",
    "start": "node server.js",
    "deploy:supabase:storage": "node scripts/deploy-supabase-storage.mjs",
    "ui:audit": "node scripts/ui-audit.mjs",
    "ui:components": "npm run storybook:build && npm run storybook:test",
    "ui:shots": "node scripts/ui-snapshots.mjs",
    "ui:verify": "playwright test e2e",
    "ui:verify:legacy": "node scripts/ui-verify-flow.mjs",
    "theme:fx:url:cinematic": "node scripts/theme-fx-toggle.mjs cinematic",
    "theme:fx:url:max": "node scripts/theme-fx-toggle.mjs max",
    "theme:fx:url:clear": "node scripts/theme-fx-toggle.mjs clear",
    "theme:fx:cinematic": "node scripts/theme-fx-toggle.mjs cinematic --open",
    "theme:fx:max": "node scripts/theme-fx-toggle.mjs max --open",
    "theme:fx:clear": "node scripts/theme-fx-toggle.mjs clear --open",
    "seed:supabase:wells": "node scripts/seed-wells.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project app",
    "test:watch": "vitest --project app"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^5.0.0",
    "canvas": "^3.2.1",
    "d3": "^7.9.0",
    "express": "^4.22.1",
    "mapbox-gl": "^3.18.1",
    "motion": "^12.35.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.14.0",
    "@vitest/browser-playwright": "^4.1.2",
    "jsdom": "^28.1.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "storybook": "^10.3.3",
    "vitest": "^4.0.18"
  }
}
