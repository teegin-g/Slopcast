{
  "name": "slopcast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "./scripts/start-backend.sh",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "circular": "madge --circular --extensions ts,tsx src/",
    "deps:check": "depcruise src/ --config .dependency-cruiser.cjs",
    "deps:graph": "depcruise src/ --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dependency-graph.svg",
    "gate": "bash .agents/validation/gate.sh",
    "preflight": "npm run format:check && npm run lint && npm run typecheck && npm run circular",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --output-dir node_modules/.cache/storybook-static",
    "storybook:test": "vitest run --project storybook",
    "start": "node server.js",
    "deploy:supabase:storage": "node scripts/deploy-supabase-storage.mjs",
    "ui:audit": "node scripts/ui-audit.mjs",
    "ui:components": "npm run storybook:build && npm run storybook:test",
    "ui:shots": "node scripts/ui-snapshots.mjs",
    "ui:verify": "playwright test e2e",
    "ui:verify:legacy": "node scripts/ui-verify-flow.mjs",
    "theme:fx:url:cinematic": "node scripts/theme-fx-toggle.mjs cinematic",
    "theme:fx:url:max": "node scripts/theme-fx-toggle.mjs max",
    "theme:fx:url:clear": "node scripts/theme-fx-toggle.mjs clear",
    "theme:fx:cinematic": "node scripts/theme-fx-toggle.mjs cinematic --open",
    "theme:fx:max": "node scripts/theme-fx-toggle.mjs max --open",
    "theme:fx:clear": "node scripts/theme-fx-toggle.mjs clear --open",
    "seed:supabase:wells": "node scripts/seed-wells.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project app",
    "test:watch": "vitest --project app"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^5.0.0",
    "canvas": "^3.2.1",
    "d3": "^7.9.0",
    "express": "^4.22.1",
    "mapbox-gl": "^3.18.1",
    "motion": "^12.35.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.14.0",
    "@vitest/browser-playwright": "^4.1.2",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "knip": "^6.1.0",
    "madge": "^8.0.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "storybook": "^10.3.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.18"
  }
}
